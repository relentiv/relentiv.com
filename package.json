{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "prepare": "husky",
    "check:precommit": "npm run lint && npm run build",
    "prebuild": "node scripts/generate-sitemap.js",
    "build": "vite build",
    "prerender": "tsx scripts/prerender.tsx",
    "postbuild": "npm run prerender",
